{
  "name": "@avatarsd-llc/libtracer-ws",
  "version": "0.5.0",
  "description": "WebSocket transport for libtracer (ADR-0029) — an RFC 6455 frame codec plus a TransportWs client that carries libtracer TLV frames over WebSocket, wire-compatible with the C++ tr::net::transport_ws. The core (@avatarsd-llc/libtracer) is a peerDependency. See docs/adr/0033-npm-subpackage-monorepo.md.",
  "author": "avatarsd LLC",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/avatarsd-llc/libtracer.git",
    "directory": "bindings/typescript/packages/transport-ws"
  },
  "homepage": "https://github.com/avatarsd-llc/libtracer#readme",
  "bugs": {
    "url": "https://github.com/avatarsd-llc/libtracer/issues"
  },
  "keywords": ["protocol", "iot", "graph", "tlv", "websocket", "transport", "rfc6455"],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ws": {
      "types": "./dist/ws.d.ts",
      "default": "./dist/ws.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@avatarsd-llc/libtracer": ">=0.5.0 <0.6.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@avatarsd-llc/libtracer": "*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.4.0",
    "ws": "^8.16.0"
  }
}
