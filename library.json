{
  "name": "libtracer",
  "version": "0.5.0",
  "description": "Lightweight decentralized graph-based networking protocol — connect sensors, microcontrollers, gateways, and apps across vendors and transports.",
  "keywords": ["protocol", "iot", "sensor", "graph", "esp32", "stm32", "esphome", "tlv"],
  "repository": {
    "type": "git",
    "url": "https://github.com/avatarsd-llc/libtracer.git"
  },
  "authors": [
    {
      "name": "avatarsd LLC",
      "url": "https://github.com/avatarsd-llc/libtracer",
      "maintainer": true
    }
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/avatarsd-llc/libtracer",
  "frameworks": "*",
  "platforms": "*",
  "headers": "libtracer/tracer.hpp",
  "export": {
    "include": [
      "core/include/**",
      "core/src/**",
      "integrations/platformio/**",
      "integrations/esp-idf/libtracer/twai_link.cpp",
      "integrations/esp-idf/libtracer/include/**",
      "library.json",
      "LICENSE",
      "README.md"
    ]
  },
  "build": {
    "includeDir": "core/include",
    "srcDir": "core/src",
    "srcFilter": "+<*> -<mem_cuda.cpp> -<transport_quic.cpp> -<transport_webtransport.cpp> -<socketcan_link.cpp>",
    "extraScript": "integrations/platformio/pio_esp32_can.py"
  }
}
